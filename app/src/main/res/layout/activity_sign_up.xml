<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#533"
    tools:context=".SignUp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇️Sign up❇️"
        android:textSize="45sp"
        android:fontFamily="cursive"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textColor="#386111"/>

    <!--    Below is the cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="22dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#E2A6E2"
            android:padding="12dp">

<!--            Below is the editText for username -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="👤 Enter your Username"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/username"
                android:layout_margin="8dp"
                android:background="#A2805F"
                android:padding="10dp"/>


            <!--            Below is the editText for Email Address -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📧 Enter your Email Address"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/email"
                android:inputType="textEmailAddress"
                android:layout_margin="8dp"
                android:background="#A2805F"
                android:padding="10dp"/>

            <!--            Below is the editText for Password -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑 Create Password"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/password"
                android:inputType="textPassword"
                android:layout_margin="8dp"
                android:background="#A2805F"
                android:padding="10dp"/>

            <!--            Below is the editText for Phone -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📞 Enter your Phone"
                android:textColorHint="#000"
                android:textSize="22sp"
                android:textColor="#000"
                android:id="@+id/phone"
                android:inputType="phone"
                android:layout_margin="8dp"
                android:background="#A2805F"
                android:padding="10dp"/>

<!--            Below is the Sign-Up button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🪪 Sign-Up"
                android:textSize="25sp"
                android:padding="10dp"
                android:layout_marginLeft="30dp"
                android:layout_marginRight="30dp"
                android:layout_marginTop="30dp"
                android:textColor="#F44336"
                android:backgroundTint="#212"
                android:id="@+id/signupBtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signin_text"
                android:textAlignment="center"
                android:textSize="23sp"
                android:textColor="#345"
                android:layout_marginTop="12dp"
                android:id="@+id/signintxt"/>



        </LinearLayout>




    </androidx.cardview.widget.CardView>

</LinearLayout>