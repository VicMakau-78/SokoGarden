<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#345"
    tools:context=".SignIn">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇Sign in❇"
        android:textSize="48sp"
        android:fontFamily="cursive"
        android:textAlignment="center"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:padding="12dp"
        android:textColor="#FFFFFF"/>

<!--    Below is the cardview-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="22dp"
        app:cardElevation="10dp"
        android:layout_margin="12dp"
        android:padding="10dp">


<!--    below is a linear layout that shall align contents vertically-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="#C7BF85">

<!--        Below is the email EditText-->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="📧 Enter Email Address"
            android:textColorHint="#000"
            android:fontFamily="sans-serif-black"
            android:id="@+id/email"
            android:textColor="#000"
            android:layout_margin="8dp"
            android:background="#77B3BF"
            android:padding="11dp"/>

        <!--        Below is the password EditText-->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="🔑 Enter Password"
            android:textColorHint="#000"
            android:id="@+id/password"
            android:fontFamily="sans-serif-black"
            android:textColor="#000"
            android:layout_margin="8dp"
            android:background="#77B3BF"
            android:padding="11dp"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🪪 Sign-In"
            android:textSize="25sp"
            android:padding="10dp"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:layout_marginTop="30dp"
            android:textColor="#F44336"
            android:backgroundTint="#212"
            android:id="@+id/signinBtn"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/signup_text"
            android:textAlignment="center"
            android:textSize="23sp"
            android:textColor="#345"
            android:layout_marginTop="12dp"
            android:id="@+id/signuptxt"/>




    </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>